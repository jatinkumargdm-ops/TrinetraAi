modules = ["nodejs-20", "web", "bash", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 pnpm --filter @workspace/crowd-intel dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3001
externalPort = 3001
exposeLocalhost = true

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 22338
externalPort = 3002

[[ports]]
localPort = 24678
externalPort = 3003

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "pnpm install --frozen-lockfile=false && pnpm --filter @workspace/crowd-intel run build"]
publicDir = "artifacts/crowd-intel/dist/public"
run = ["sh", "-c", "pnpm --filter @workspace/crowd-intel run start"]

[userenv]


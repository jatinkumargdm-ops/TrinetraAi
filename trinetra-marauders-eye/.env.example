# =============================================================================
# Local development — everything below is optional. Just `pnpm dev` works.
# =============================================================================

# Optional. Leave unset for zero-setup local dev — the app falls back to a
# JSON file at .local/users.json so you don't need any database.
# DATABASE_URL=postgresql://user:pass@localhost:5432/trinetra

# Optional. Auto-generated and persisted to .local/jwt-secret on first run.
# JWT_SECRET=change-me-to-a-long-random-string

# Optional. Defaults to 5000.
# PORT=5000

# Optional. Set to "true" to enable a self-signed local HTTPS cert.
# Recommended instead: run `pnpm tunnel` for a valid public HTTPS URL.
# HTTPS=true

# =============================================================================
# Production / Railway / Render / Fly / Heroku — REQUIRED
# =============================================================================
# These MUST be set as host environment variables (not committed to git):
#
#   DATABASE_URL  Postgres connection string. On Railway, click "+ New" →
#                 "Database" → "Postgres", then in your service "Variables" tab
#                 add a reference: DATABASE_URL = ${{ Postgres.DATABASE_URL }}
#                 SSL is enabled automatically for non-localhost hosts.
#
#   JWT_SECRET    Long random string — sign sessions. Generate with:
#                   openssl rand -base64 48
#                 If unset, every restart will sign all users out.
#
# PORT is provided by Railway/Render automatically — do NOT hardcode it.
# NODE_ENV=production is set by `pnpm start`.
